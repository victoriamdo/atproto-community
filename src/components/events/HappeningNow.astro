---
import {
  eventAnchorId,
  formatStartsIn,
  formatTimeLeft,
  selectHappeningNowGroups,
} from "../../lib/community/happening-now";

interface HappeningNowEvent {
  atUri: string;
  uri: string;
  name: string;
  startsAt: Date;
  endsAt?: Date;
  location?: string;
  mode?: "inperson" | "virtual" | "hybrid";
  source?: string;
}

interface Props {
  events: HappeningNowEvent[];
}

const { events } = Astro.props;

const groups = selectHappeningNowGroups(events);
const nowMs = Date.now();

const sections = [
  {
    id: "now",
    heading: "Now",
    label: "Live",
    items: groups.now,
    empty: "Nothing live right now.",
  },
  {
    id: "today",
    heading: "Today",
    label: "Today",
    items: groups.today,
    empty: "Nothing else today.",
  },
  {
    id: "week",
    heading: "This week",
    label: "This week",
    items: groups.thisWeek,
    empty: "Nothing else this week.",
  },
];
const hasItems = sections.some((section) => section.items.length > 0);

// SSR fallback for the absolute start time; the client script swaps this
// for the visitor's local time zone on hydration.
const startTimeFmt = new Intl.DateTimeFormat("en-US", {
  hour: "numeric",
  minute: "2-digit",
  timeZone: "UTC",
});
---

{
  hasItems && (
    <section class="now-strip" aria-labelledby="now-heading">
      <div class="now-content">
        <header class="now-header">
          <h2 id="now-heading" class="now-header__title">
            {groups.now.length > 0 && (
              <span class="now-pulse" aria-hidden="true">
                <span class="now-pulse__dot" />
                <span class="now-pulse__ring" />
              </span>
            )}
            <span>At a glance</span>
          </h2>
          <p class="now-header__sub">Live and upcoming community events.</p>
        </header>

        <div class="now-groups">
          {sections.map((section, sectionIndex) => (
            <section
              class="now-group"
              aria-labelledby={`now-${section.id}`}
              data-now-section={section.id}
            >
              <h3 id={`now-${section.id}`} class="now-group__title">
                {section.heading}
              </h3>
              <div class="now-cards" data-now-cards>
                {section.items.map((item, itemIndex) => {
                    const status = item.isLive ? "live" : "soon";
                    const relative = item.isLive
                      ? formatTimeLeft(item.endsAt.getTime() - nowMs)
                      : formatStartsIn(item.startsAt.getTime() - nowMs);
                    const startIso = item.startsAt.toISOString();
                    const endIso = item.endsAt.toISOString();
                    return (
                      <a
                        class:list={["now-card", `now-card--${status}`]}
                        href={`#${eventAnchorId(item.event.atUri)}`}
                        style={`--stagger:${sectionIndex + itemIndex}`}
                        data-event-starts-at={startIso}
                        data-event-ends-at={endIso}
                      >
                        <div class="now-card__head">
                          <span class="now-card__status">
                            <span
                              class="now-card__live-dot"
                              aria-hidden="true"
                              data-status-live-icon
                              hidden={!item.isLive}
                            />
                            <svg
                              viewBox="0 0 12 12"
                              width="11"
                              height="11"
                              aria-hidden="true"
                              data-status-soon-icon
                              hidden={item.isLive}
                            >
                              <circle
                                cx="6"
                                cy="6"
                                r="5"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.4"
                              />
                              <path
                                d="M6 3.2v3l2 1.2"
                                stroke="currentColor"
                                stroke-width="1.4"
                                fill="none"
                                stroke-linecap="round"
                              />
                            </svg>
                            <span data-status-label>{section.label}</span>
                          </span>
                          <span
                            class="now-card__relative"
                            data-relative
                            data-relative-mode={status}
                          >
                            {relative}
                          </span>
                        </div>

                        <h4 class="now-card__name">{item.event.name}</h4>

                        <div class="now-card__meta">
                          <time
                            class="now-card__time"
                            datetime={startIso}
                            data-localize-time
                          >
                            {startTimeFmt.format(item.event.startsAt)} UTC
                          </time>
                          {item.event.location && (
                            <>
                              <span class="now-card__sep" aria-hidden="true">
                                ·
                              </span>
                              <span class="now-card__loc">
                                {item.event.location}
                              </span>
                            </>
                          )}
                        </div>
                      </a>
                    );
                  })}
                <p class="now-empty" data-now-empty hidden={section.items.length > 0}>
                  {section.empty}
                </p>
              </div>
            </section>
          ))}
        </div>
      </div>
    </section>
  )
}

<style>
  .now-strip {
    position: relative;
    margin-block: var(--space-lg);
    padding-block: var(--space-lg);
    padding-inline: var(--space-base);
    border-radius: var(--radius-md);
    border: 1px solid var(--border);
    background: color-mix(in oklch, var(--primary) 4%, var(--background));
  }

  .now-content {
    position: relative;
    z-index: 1;
  }

  .now-header {
    margin-bottom: var(--space-md);
  }
  .now-header__title {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-base);
    font-weight: 700;
    margin: 0;
    color: var(--foreground);
  }
  .now-header__sub {
    color: var(--foreground-secondary);
    font-size: var(--text-xs);
    margin-top: var(--space-xs);
    line-height: var(--leading-normal);
    max-width: 55ch;
  }

  /* Pulsing indicator next to "Happening now" heading */
  .now-pulse {
    position: relative;
    display: inline-flex;
    width: 8px;
    height: 8px;
    flex-shrink: 0;
  }
  .now-pulse__dot {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: var(--primary);
  }
  .now-pulse__ring {
    display: none;
  }

  .now-groups {
    display: grid;
    gap: var(--space-md);
  }

  .now-group {
    display: grid;
    gap: var(--space-sm);
  }

  .now-group__title {
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--foreground-secondary);
  }

  .now-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 220px), 1fr));
    gap: var(--space-sm);
  }

  .now-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding: var(--space-md);
    border-radius: var(--radius-sm);
    background: var(--card);
    border: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s ease;
  }
  .now-empty {
    margin: 0;
    padding: var(--space-md);
    border: 1px dashed var(--border);
    border-radius: var(--radius-sm);
    color: var(--foreground-secondary);
    font-size: var(--text-xs);
    line-height: var(--leading-normal);
  }
  .now-card:hover {
    border-color: color-mix(in oklch, var(--primary) 40%, var(--border));
  }
  .now-card:focus-visible {
    outline: 2px solid var(--ring);
    outline-offset: 2px;
  }

  .now-card--live {
    border-color: color-mix(in oklch, var(--primary) 40%, var(--border));
  }

  .now-card__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm);
  }

  .now-card__status {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--foreground-secondary);
  }
  .now-card--live .now-card__status {
    color: var(--primary);
  }

  .now-card__live-dot {
    position: relative;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--primary);
  }
  .now-card__live-dot::before {
    content: "";
    position: absolute;
    inset: -1px;
    border-radius: 50%;
    border: 1.5px solid var(--primary);
    opacity: 0;
    animation: now-card-live-pulse 2.4s ease-out infinite;
    pointer-events: none;
  }
  @keyframes now-card-live-pulse {
    0% {
      transform: scale(1);
      opacity: 0.55;
    }
    80%,
    100% {
      transform: scale(3.2);
      opacity: 0;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .now-card__live-dot::before {
      animation: none;
    }
  }

  .now-card__relative {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--foreground-secondary);
    font-variant-numeric: tabular-nums;
  }

  .now-card__name {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    margin: 0;
    line-height: var(--leading-tight);
    color: var(--foreground);
    text-wrap: balance;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .now-card__meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: auto;
    font-size: var(--text-xs);
    color: var(--foreground-muted);
  }
  .now-card__time {
    font-weight: 600;
    color: var(--foreground-secondary);
    font-variant-numeric: tabular-nums;
  }
  .now-card__sep {
    opacity: 0.5;
  }
  .now-card__loc {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 22ch;
  }

  @media (max-width: 640px) {
    .now-strip {
      padding-block: var(--space-md);
      padding-inline: var(--space-sm);
    }
    .now-cards {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  import {
    formatStartsIn,
    formatTimeLeft,
  } from "../../lib/community/happening-now";
  import {
    formatLocalEventClock,
    readEventTiming,
  } from "../../lib/client/event-time";

  function localizeTimes() {
    document
      .querySelectorAll<HTMLTimeElement>("[data-localize-time]")
      .forEach((el) => {
        const iso = el.getAttribute("datetime");
        if (!iso) return;
        el.textContent = formatLocalEventClock(new Date(iso));
      });
  }

  function tickNowStrip() {
    const now = Date.now();
    document.querySelectorAll<HTMLElement>(".now-card").forEach((card) => {
      const startsAt = card.dataset.eventStartsAt;
      const endsAt = card.dataset.eventEndsAt;
      const rel = card.querySelector<HTMLElement>("[data-relative]");
      if (!startsAt || !endsAt || !rel) return;
      const start = new Date(startsAt).getTime();
      const end = new Date(endsAt).getTime();
      const mode = rel.dataset.relativeMode as "live" | "soon" | undefined;
      if (!mode) return;

      if (mode === "live") {
        rel.textContent = formatTimeLeft(end - now);
      } else {
        const until = start - now;
        if (until <= 0) {
          rel.dataset.relativeMode = "live";
          rel.textContent = formatTimeLeft(end - now);
          return;
        }
        rel.textContent = formatStartsIn(until);
      }
    });
  }

  function setStatus(card: HTMLElement, mode: "live" | "soon", label: string) {
    card.classList.toggle("now-card--live", mode === "live");
    card.classList.toggle("now-card--soon", mode === "soon");

    const liveIcon = card.querySelector<HTMLElement>("[data-status-live-icon]");
    const soonIcon = card.querySelector<HTMLElement>("[data-status-soon-icon]");
    const labelEl = card.querySelector<HTMLElement>("[data-status-label]");
    const rel = card.querySelector<HTMLElement>("[data-relative]");

    liveIcon?.toggleAttribute("hidden", mode !== "live");
    soonIcon?.toggleAttribute("hidden", mode === "live");
    if (labelEl) labelEl.textContent = label;
    if (rel) rel.dataset.relativeMode = mode;
  }

  function regroupNowStrip() {
    const now = new Date();
    const sections = new Map(
      Array.from(document.querySelectorAll<HTMLElement>("[data-now-section]")).map(
        (section) => [section.dataset.nowSection, section],
      ),
    );
    const buckets = {
      now: [] as HTMLElement[],
      today: [] as HTMLElement[],
      week: [] as HTMLElement[],
    };

    document.querySelectorAll<HTMLElement>(".now-card").forEach((card) => {
      const timing = readEventTiming(card, now);
      if (!timing || timing.state === "past") return;

      if (timing.state === "live") {
        buckets.now.push(card);
        setStatus(card, "live", "Live");
      } else if (timing.state === "today") {
        buckets.today.push(card);
        setStatus(card, "soon", "Today");
      } else if (timing.state === "week") {
        buckets.week.push(card);
        setStatus(card, "soon", "This week");
      }
    });

    buckets.now.sort(
      (a, b) =>
        new Date(a.dataset.eventEndsAt ?? 0).getTime() -
        new Date(b.dataset.eventEndsAt ?? 0).getTime(),
    );
    buckets.today.sort(
      (a, b) =>
        new Date(a.dataset.eventStartsAt ?? 0).getTime() -
        new Date(b.dataset.eventStartsAt ?? 0).getTime(),
    );
    buckets.week.sort(
      (a, b) =>
        new Date(a.dataset.eventStartsAt ?? 0).getTime() -
        new Date(b.dataset.eventStartsAt ?? 0).getTime(),
    );

    for (const [id, section] of sections) {
      if (!id) continue;
      const cards = section.querySelector<HTMLElement>("[data-now-cards]");
      const empty = section.querySelector<HTMLElement>("[data-now-empty]");
      const items = buckets[id as keyof typeof buckets] ?? [];
      if (!cards || !empty) continue;

      items.forEach((card) => cards.insertBefore(card, empty));
      empty.toggleAttribute("hidden", items.length > 0);
    }
  }

  localizeTimes();
  regroupNowStrip();
  tickNowStrip();
  setInterval(tickNowStrip, 30000);
  setInterval(regroupNowStrip, 30000);
</script>
